		"@tauri-apps/plugin-notification": "^2.3.3",
		"@tauri-apps/plugin-store": "^2.4.2",
		"@tauri-apps/plugin-updater": "^2.10.0",
		"dompurify": "^3.3.1",
		"livekit-client": "^2.17.2",
		"marked": "^17.0.3",
		"shiki": "^3.22.0"
	}
}
