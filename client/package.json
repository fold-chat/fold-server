		"eslint": "^9.0.0",
		"eslint-plugin-svelte": "^3.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.0.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"dompurify": "^3.3.1",
		"marked": "^17.0.3",
		"shiki": "^3.22.0"
	}
